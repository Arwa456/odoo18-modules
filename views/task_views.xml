<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    List view -->
    <record id="view_task_manager_list" model="ir.ui.view">
        <field name="name">task.manager.list</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="assigned_to"/>
                <field name="deadline"/>
                <field name="priority"/>
                <field name="done"/>
            </list>
        </field>
    </record>

    <!--    Form View-->
    <record id="view_task_manager_form" model="ir.ui.view">
        <field name="name">task.manager,form</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="assigned_to"/>
                        <field name="deadline"/>
                        <field name="priority"/>
                        <field name="done"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Action -->
    <record id="action_task_manager" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">task.manager</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--    Menu -->
    <menuitem id="menu_task_manager_root"
              name="Task Manager"
              sequence="10"/>
    <menuitem id="menu_task_manager"
              name="Tasks"
              parent="menu_task_manager_root"
              action="action_task_manager"
              sequence="1"/>
</odoo>